<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Кофейня ПРОСТО</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <!-- Шапка -->
        <header class="header">
            <h1>☕ ПРОСТО</h1>
            <p>Кофейня на Мате Залки, 17</p>
        </header>

        <!-- Категории -->
        <div class="categories" id="categories"></div>

        <!-- Меню -->
        <div class="menu" id="menu"></div>

        <!-- Корзина (плавающая кнопка) -->
        <div class="cart-float" id="cartFloat" onclick="showCart()">
            🛒 <span id="cartCount">0</span>
        </div>
    </div>

    <!-- Модальное окно корзины -->
    <div class="modal" id="cartModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>🛒 Ваша корзина</h2>
                <button class="close-btn" onclick="hideCart()">✕</button>
            </div>
            <div class="cart-items" id="cartItems"></div>
            <div class="cart-total">
                <strong>Итого: <span id="cartTotal">0</span>₽</strong>
            </div>
            <button class="order-btn" onclick="sendOrder()">✅ Оформить заказ</button>
        </div>
    </div>

    <script src="app.js"></script>
</body>
</html>
